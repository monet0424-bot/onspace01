rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    match /admins/{adminId} {
      allow read: if isSignedIn() && adminId == request.auth.uid;
    }

    match /inquiries/{inquiryId} {
      function isValidInquiry(data) {
        return data.keys().hasAll(['name', 'email', 'type', 'message', 'createdAt', 'status'])
          && data.keys().size() == 6
          && data.name is string && data.name.size() <= 100
          && data.email is string && data.email.size() <= 100
          && data.type is string && data.type.size() <= 50
          && data.message is string && data.message.size() <= 2000
          && data.status in ['new', 'read', 'replied'];
      }

      allow create: if isValidInquiry(request.resource.data)
        && request.resource.data.createdAt == request.time;
      
      allow read, update, delete: if isAdmin();
    }
    
    match /test/connection {
      allow get: if true;
    }
  }
}
