{
  "entities": {
    "inquiry": {
      "title": "Inquiry",
      "description": "User inquiries from the contact form",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "type": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["new", "read", "replied"] }
      },
      "required": ["name", "email", "type", "message", "createdAt", "status"]
    }
  },
  "firestore": {
    "inquiries": {
      "schema": "inquiry",
      "description": "Collection of visitor inquiries"
    }
  }
}
